\c 148
\q1
\v 1 Louez le SEIGNEUR !\f + \fr 148:1 \ft Hébreu : יה Yah\f* 
\q2 Louez le SEIGNEUR\f + \fr 148:1 \ft SEIGNEUR ou DIEU en majuscules traduit l'hébreu יהוה Yahvé, sauf mention contraire précisant la forme courte יה Yah.\f* depuis les cieux !
\q2 Louez-le dans les lieux très hauts !
\q1
\v 2 Louez-le, vous tous ses anges !
\q2 Louez-le, vous toutes ses armées !
\q1
\v 3 Louez-le, soleil et lune !
\q2 Louez-le, vous toutes, étoiles brillantes !
\q1
\v 4 Louez-le, cieux des cieux,
\q2 et vous, les eaux qui êtes au-dessus des cieux !
\q1
\v 5 Qu'ils louent le nom du SEIGNEUR,
\q2 car il a commandé, et ils ont été créés.
\q1
\v 6 Il les a affermis pour toujours et à perpétuité.
\q2 Il a donné une loi qui ne passera point.
\q1
\v 7 Louez le SEIGNEUR depuis la terre,
\q2 vous, monstres marins, et vous tous, abîmes,
\q1
\v 8 feu et grêle, neige et brouillard,
\q2 vents impétueux, qui exécutez sa parole,
\q1
\v 9 montagnes et toutes les collines,
\q2 arbres fruitiers et tous les cèdres,
\q1
\v 10 bêtes sauvages et tout le bétail,
\q2 reptiles et oiseaux ailés,
\q1
\v 11 rois de la terre et tous les peuples,
\q2 princes et tous les juges de la terre,
\q1
\v 12 jeunes hommes et jeunes filles,
\q2 vieillards et enfants !
\q1
\v 13 Qu'ils louent le nom du SEIGNEUR,
\q2 car son nom seul est élevé.
\q2 Sa majesté est au-dessus de la terre et des cieux.
\q1
\v 14 Il a relevé la corne de son peuple,
\q2 sujet de louange pour tous ses fidèles,
\q2 pour les enfants d'Israël, le peuple qui est près de lui.
\q1 Louez le SEIGNEUR !\f + \fr 148:14 \ft Hébreu : יה Yah\f* 
