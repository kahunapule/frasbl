\c 136
\q1
\v 1 Rendez grâce au SEIGNEUR, car il est bon,
\q2 car son amour fidèle dure à toujours.
\q1
\v 2 Rendez grâce au Dieu des dieux,
\q2 car son amour fidèle dure à toujours.
\q1
\v 3 Rendez grâce au Seigneur des seigneurs,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 4 à celui qui seul fait de grands prodiges,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 5 à celui qui a fait les cieux avec intelligence,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 6 à celui qui a étendu la terre au-dessus des eaux,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 7 à celui qui a fait les grands luminaires,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 8 le soleil pour dominer le jour,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 9 la lune et les étoiles pour dominer la nuit,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 10 à celui qui frappa les premiers-nés des Égyptiens,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 11 et qui fit sortir Israël du milieu d'eux,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 12 à main forte et à bras étendu,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 13 à celui qui fendit la mer Rouge en deux,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 14 et qui fit passer Israël au milieu d'elle,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 15 et qui précipita le Pharaon et son armée dans la mer Rouge,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 16 à celui qui conduisit son peuple dans le désert,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 17 à celui qui frappa de grands rois,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 18 et qui tua des rois puissants,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 19 Sihon, roi des Amoréens,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 20 Og, roi de Basan,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 21 et qui donna leur pays en héritage,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 22 en héritage à Israël, son serviteur,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 23 lui qui se souvint de nous dans notre bassesse,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 24 et qui nous a délivrés de nos adversaires,
\q2 car son amour fidèle dure à toujours ;
\q1
\v 25 qui donne la nourriture à toute créature,
\q2 car son amour fidèle dure à toujours.
\q1
\v 26 Rendez grâce au Dieu des cieux,
\q2 car son amour fidèle dure à toujours.